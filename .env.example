# Key NAMES only — real values live in .env (gitignored). Fill in as phases need them.
# NOTHING here is required to run locally: the default stack is Ollama + embedded Qdrant,
# neither of which authenticates.

# Generation. Read via llm.api_key_env in configs/config.yaml. Ollama ignores it entirely;
# set it only when you point llm.base_url at a hosted OpenAI-compatible provider (Groq etc).
LLM_API_KEY=

# Optional: raises the NCBI E-utilities rate limit 3 -> 10 req/s for the (disabled) PMC
# ingester. Read via sources.pmc.api_key_env.
NCBI_API_KEY=

# Optional: higher Hugging Face download limits when pulling MedQuAD / the embedding model.
HF_TOKEN=

# Only needed if you move Qdrant off embedded mode (vector_store.path) to a server/Cloud.
QDRANT_URL=
QDRANT_API_KEY=